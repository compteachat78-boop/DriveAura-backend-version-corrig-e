NODE_ENV=production
PORT=10000

# Base de données
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/driveaura

# Sécurité admin
ADMIN_EMAIL=votre-email@exemple.com
ADMIN_PASSWORD=un_mot_de_passe_fort
ADMIN_SECRET_PATH=un-chemin-secret-difficile-a-deviner
JWT_SECRET=une_longue_chaine_aleatoire_64_caracteres_minimum

# Stockage médias (Cloudinary)
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# Moteurs IA (cascade Groq -> Gemini -> OpenRouter)
GROQ_API_KEY=gsk_xxx
GOOGLE_API_KEY=AIzaSy_xxx
OPENROUTER_API_KEY=sk-or-xxx

# CORS - domaines autorisés à appeler l'API, séparés par des virgules
# Laisser vide ou "*" seulement si le frontend est servi par ce même serveur
ALLOWED_ORIGINS=https://votre-site.netlify.app

# Nombre max de messages/jour qu'un même contact peut envoyer à Hinata avant
# qu'elle ne se mette en pause (anti-spam volume)
MAX_MESSAGES_PER_DAY=20
